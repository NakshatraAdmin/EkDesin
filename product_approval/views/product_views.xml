    <record id="view_template_property_form_inherit_view" model="ir.ui.view">
        <field name="name">product.template.form.sale.property.inherit</field>
        <field name="model">product.template</field>
        <field name="priority">5</field>
        <field name="inherit_id" ref="stock.view_template_property_form" />
        <field name="arch" type="xml">
            <xpath expr="//field[@name='is_storable']" position="attributes">
                <attribute
                    name="readonly"
                >state in ('pending_approval', 'approved')</attribute>
            </xpath>
        </field>
    </record>

    <record id="product_template_form_view" model="ir.ui.view">
        <field name="name">product.template.form.inherit</field>
        <field name="model">product.template</field>
        <field name="priority">5</field>
        <field name="inherit_id" ref="product.product_template_form_view" />
        <field name="arch" type="xml">
            <header position="attributes">
                <attribute name="invisible">1</attribute>
            </header>
            <xpath expr="//sheet" position="before">
                <header>
                    <button
                        class="btn btn-primary"
                        name="button_send_for_approval"
                        type="object"
                        invisible="not is_approval_required or state != False"
                        string="Send For Approval"
                        data-hotkey="q"
                    />
                    <button
                        class="btn btn-primary"
                        name="button_send_to_draft"
                        type="object"
                        invisible="state != 'rejected'"
                        string="Set to Draft"
                        data-hotkey="q"
                    />
                    <button
                        name="action_approve"
                        type="object"
                        string="Approve"
                        class="btn-primary"
                        invisible="not is_show_approve_reject_button"
                    />
                    <button
                        name="action_reject"
                        type="object"
                        string="Reject"
                        class="btn-danger"
                        invisible="not is_show_approve_reject_button"
                    />
                    <field
                        name="state"
                        widget="statusbar"
                        statusbar_visible="pending_approval,approved"
                    />
                </header>
            </xpath>
            <xpath expr="//field[@name='name']" position="attributes">
                <attribute
                    name="readonly"
                >state in ('pending_approval', 'approved')</attribute>
            </xpath>
            <xpath expr="//field[@name='sale_ok']" position="attributes">
                <attribute
                    name="readonly"
                >state in ('pending_approval', 'approved')</attribute>
            </xpath>
            <xpath expr="//field[@name='type']" position="attributes">
                <attribute
                    name="readonly"
                >state in ('pending_approval', 'approved')</attribute>
            </xpath>
            <xpath expr="//field[@name='list_price']" position="attributes">
                <attribute
                    name="readonly"
                >state in ('pending_approval', 'approved')</attribute>
            </xpath>
            <xpath expr="//field[@name='taxes_id']" position="attributes">
                <attribute
                    name="readonly"
                >state in ('pending_approval', 'approved')</attribute>
            </xpath>
            <xpath expr="//field[@name='standard_price']" position="attributes">
                <attribute
                    name="readonly"
                >state in ('pending_approval', 'approved')</attribute>
            </xpath>
            <xpath expr="//field[@name='supplier_taxes_id']" position="attributes">
                <attribute
                    name="readonly"
                >state in ('pending_approval', 'approved')</attribute>
            </xpath>
            <xpath expr="//field[@name='categ_id']" position="attributes">
                <attribute
                    name="readonly"
                >state in ('pending_approval', 'approved')</attribute>
            </xpath>
        </field>
    </record>
    <record id="product_form_view_procurement_button_inherit_custom" model="ir.ui.view">
        <field name="name">product.template.procurement.inherit.custom</field>
        <field name="model">product.template</field>
        <field
            name="inherit_id"
            ref="stock.product_template_form_view_procurement_button"
        />
        <field name="arch" type="xml">
            <!-- Inherit and update "Update Quantity" button -->
            <xpath
                expr="//button[@name='action_update_quantity_on_hand']"
                position="attributes"
            >
                <attribute
                    name="invisible"
                >not is_storable or state != 'approved'</attribute>
            </xpath>

            <!-- Inherit and update "Replenish" button -->
            <xpath
                expr="//header/button[@name='%(stock.action_product_replenish)d']"
                position="attributes"
            >
                <attribute
                    name="invisible"
                >type != 'consu' or state != 'approved'</attribute>
            </xpath>
        </field>
    </record>
    <record id="view_product_product_search_list" model="ir.ui.view">
        <field name="name">product.product.search</field>
        <field name="model">product.product</field>
        <field name="arch" type="xml">
            <search string="Search Products Items">
                <filter
                    name="assigned_approvals"
                    string="My Assigned Approvals"
                    domain="[('assigned_approver_id', '=', uid)]"
                />
            </search>
        </field>
    </record>
    <record id="view_product_template_search_list" model="ir.ui.view">
        <field name="name">product.template.search</field>
        <field name="model">product.template</field>
        <field name="arch" type="xml">
            <search string="Search Products Items">
                <filter
                    name="assigned_approvals"
                    string="My Assigned Approvals"
                    domain="[('assigned_approver_id', '=', uid)]"
                />
            </search>
        </field>
    </record>
    <record id="product_product_approval_list" model="ir.ui.view">
        <field name="name">product.product.view.list</field>
        <field name="model">product.product</field>
        <field name="arch" type="xml">
            <list>
                <field name="name" />
                <field name="default_code" />
                <field name="product_tag_ids" />
                <field name="list_price" />
                <field name="standard_price" />
                <field name="assigned_approver_id" />
                <field name="approver_state" />
            </list>
        </field>
    </record>
    <record id="product_template_approval_list" model="ir.ui.view">
        <field name="name">product.template.view.list</field>
        <field name="model">product.template</field>
        <field name="arch" type="xml">
            <list>
                <field name="name" />
                <field name="default_code" />
                <field name="product_tag_ids" />
                <field name="list_price" />
                <field name="standard_price" />
                <field name="assigned_approver_id" />
                <field name="approver_state" />
            </list>
        </field>
    </record>
    <record id="product_product_approval_action" model="ir.actions.act_window">
        <field name="name">Approval Request for Product variants</field>
        <field name="res_model">product.product</field>
        <field name="domain">[('state', '=', 'pending_approval')]</field>
        <field name="view_mode">list,form</field>
        <field
            name="context"
        >{'create': False,'search_default_assigned_approvals': 1}</field>
        <field name="view_id" ref="product_product_approval_list" />
        <field name="search_view_id" ref="view_product_product_search_list" />
    </record>
    <record id="product_template_approval_action" model="ir.actions.act_window">
        <field name="name">Approval Request for Products</field>
        <field name="res_model">product.template</field>
        <field name="domain">[('state', '=', 'pending_approval')]</field>
        <field name="view_mode">list,form</field>
        <field
            name="context"
        >{'create': False, 'search_default_assigned_approvals': 1}</field>
        <field name="view_id" ref="product_template_approval_list" />
        <field name="search_view_id" ref="view_product_template_search_list" />
    </record>
    <menuitem
        id="menu_product_product_approval_action"
        action="product_product_approval_action"
        parent="stock.menu_stock_inventory_control"
        sequence="50"
    />
    <menuitem
        id="menu_product_template_approval_action"
        action="product_template_approval_action"
        parent="stock.menu_stock_inventory_control"
        sequence="50"
    />
</odoo>

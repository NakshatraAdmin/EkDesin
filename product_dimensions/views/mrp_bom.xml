<?xml version="1.0" encoding="UTF-8"?>
<odoo>
       <record id="mrp_bom_form_inherit_dimensions" model="ir.ui.view">
        <field name="name">mrp.bom.form.inherit.dimensions</field>
        <field name="model">mrp.bom</field>
        <field name="inherit_id" ref="mrp.mrp_bom_form_view"/>
        <field name="arch" type="xml">
           <xpath expr="//field[@name='bom_line_ids']/list/field[@name='product_id']" position="after">

                <field name="show_dimensions" invisible="1"/>

               
                <field name="length"
                       attrs="{'invisible': [('show_dimensions','=',False)]}"/>
                <field name="width"
                       attrs="{'invisible': [('show_dimensions','=',False)]}"/>
                <field name="height"
                       attrs="{'invisible': [('show_dimensions','=',False)]}"/>
                 

            </xpath>
        </field>
    </record>
</odoo>

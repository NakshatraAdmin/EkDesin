<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <record id="product_template_form_view_dimension_summary" model="ir.ui.view">
        <field name="name">product.template.view.form.inherit.dimension.summary</field>
        <field name="model">product.template</field>
        <field name="inherit_id" ref="product.product_template_only_form_view"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='show_dimensions']" position="after">
                <field name="dimension_summary" readonly="1" string="Dimension Summary" 
                       widget="text" placeholder="Shows: X cft :- Y pcs"/>
            </xpath>
        </field>
    </record>
</odoo>

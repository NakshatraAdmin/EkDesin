<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <record id="product_product_form_view_dimensions" model="ir.ui.view">
        <field name="name">product.product.view.form.inherit.dimensions</field>
        <field name="model">product.product</field>
        <field name="inherit_id" ref="product.product_normal_form_view"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='invoice_policy']" position="after">
                <field name="show_dimensions"/>
                <field name="length" invisible="not show_dimensions"/>
                <field name="width" invisible="not show_dimensions"/>
                <field name="height" invisible="not show_dimensions"/>
            </xpath>
        </field>
    </record>
    <record id="product_product_stock_tree_inherit_leng_width" model="ir.ui.view">
        <field name="name">product.product.stock.view.tree.inherit.product.l.w.h</field>
        <field name="model">product.product</field>
        <field name="inherit_id" ref="stock.product_product_stock_tree"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='uom_id']" position="after">
                <field name="dimension_summary"/>
            </xpath>
        </field>
    </record>
</odoo>

<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <record id="mrp_production_form_view_dimensions" model="ir.ui.view">
        <field name="name">mrp.production.form.dimensions</field>
        <field name="model">mrp.production</field>
        <field name="inherit_id" ref="mrp.mrp_production_form_view"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='move_raw_ids']/list/field[@name='width']" position="after">
                <field name="show_dimensions" readonly="1"/>

                <field name="assume_width"/>
                <field name="assume_length"/>
                <field name="assume_height"/>
<!--                 <field name="dary_product_uom_qty"/>
 -->                
            </xpath>
            <!--  <xpath expr="//field[@name='move_raw_ids']/list/field[@name='sec_uom_id']" position="before">
                <field name="sec_uom" invisible="show_dimensions != True" readonly="1"/>
                </xpath> -->
        </field>
    </record>
</odoo>

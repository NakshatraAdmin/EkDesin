<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <record id="product_template_form_view_dimensions" model="ir.ui.view">
        <field name="name">product.template.view.form.inherit.dimensions</field>
        <field name="model">product.template</field>
        <field name="inherit_id" ref="product.product_template_only_form_view"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='invoice_policy']" position="after">
                <field name="show_dimensions"/>
                <field name="height" invisible="not show_dimensions"/>
                <field name="length" invisible="not show_dimensions"/>
                <field name="width" invisible="not show_dimensions"/>
            </xpath>
        </field>
    </record>
</odoo>

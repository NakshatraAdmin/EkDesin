<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <record id="view_picking_form_inherit_dimensions" model="ir.ui.view">
        <field name="name">stock.picking.form.dimensions</field>
        <field name="model">stock.picking</field>
        <field name="inherit_id" ref="stock.view_picking_form"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='move_ids_without_package']/list/field[@name='product_uom']" position="after">
                <field name="show_dimensions" readonly="1" invisible="not purchase_line_id"/>
                <field name="length" readonly="1" invisible="not purchase_line_id"/>
                <field name="width" readonly="1" invisible="not purchase_line_id"/>
                <field name="height" readonly="1" invisible="not purchase_line_id"/>
                <field name="assume_length" invisible="not purchase_line_id"/>
                <field name="assume_width" invisible="not purchase_line_id"/>
                <field name="assume_height" invisible="not purchase_line_id"/>
            </xpath>
        </field>
    </record>
</odoo>

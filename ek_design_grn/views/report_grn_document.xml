<?xml version="1.0" encoding="utf-8"?>
<odoo>
<template id="report_grn_custom">
<t t-call="web.html_container">

        <t t-set="o" t-value="o.with_context(lang=o.partner_id.lang)"/>
          <div style="text-align:left; margin-bottom:10px;">
            <img t-if="o.company_id.logo"
                 t-att-src="image_data_uri(o.company_id.logo)"
                 style="max-height:80px;"/>
        </div>
        <div style="text-align:center; margin-top:-50px;">
            <h2 style="font-weight:700; text-transform:uppercase;">GOODS RECEIPT NOTE (GRN)</h2>
        </div>
        <table style="
        width:100%;
        border:1px solid black;
        border-collapse:collapse;
        margin-top:10px;
    ">
        <tr>
            <td style="padding:6px; width:10%; text-align:center;">
                Rev No
                <span t-esc="o.revision_no"/>
            </td>
            <td style="padding:6px; width:40%; text-align:right;">
                Rev Date
                <t t-esc="o.revision_date and o.revision_date.strftime('%d/%m/%Y') or ''"/>
            <td style="padding:6px; width:40%;text-align:right;">
                Doc No
                <span t-esc="o.doc_no"/>
            </td>
            
            
            </td>
        </tr>
    </table>
    <div class="page" style="padding-top:0;">

        

        <table style="width:100%; border-collapse:collapse; margin-top:8px; font-size:15px;">
            <tr>

                <!-- Bill To -->
                
                 <td style="width:50%; border:1px solid #000; padding:5px;">
                    <strong>Vendor</strong><br/>
                    <t t-esc="o.partner_id.name"/><br/>
                    <t t-esc="o.partner_id.street or ''"/><br/>
                    <t t-esc="o.partner_id.street2 or ''"/><br/>
                    <t t-esc="(o.partner_id.city or '') + ' ' + (o.partner_id.zip or '')"/><br/>
                    <t t-esc="o.partner_id.state_id.name or ''"/> ,
                    <t t-esc="o.partner_id.country_id.name or ''"/><br/>
                    GSTIN: <t t-esc="o.partner_id.vat or '-'"/>
                </td>
                <!-- Ship To -->
                <td style="width:50%; border:1px solid #000; padding:5px;">
                    <strong>Ship To</strong><br/>
                    <t t-esc="o.company_id.name"/><br/>
                    <t t-esc="o.company_id.street or ''"/><br/>
                    <t t-esc="o.company_id.street2 or ''"/><br/>
                    <t t-esc="(o.company_id.city or '') + ' ' + (o.company_id.zip or '')"/><br/>
                    <t t-esc="o.company_id.state_id.name or ''"/> ,
                    <t t-esc="o.company_id.country_id.name or ''"/><br/>
                    GSTIN: <t t-esc="o.company_id.vat or '-'"/>
                </td>

            </tr>
        </table>
        <table style="width:100%; border-collapse:collapse; font-size:15px;">
            <tr>

                <!-- Supplier -->
                <td style="width:50%; border:1px solid #000; padding:5px;">
                    <strong><t t-esc="o.company_id.name"/></strong><br/>
                    <t t-esc="o.company_id.street or ''"/><br/>
                    <t t-esc="o.company_id.street2 or ''"/><br/>
                    <t t-esc="(o.company_id.city or '') + ' ' + (o.company_id.zip or '')"/><br/>
                    <t t-esc="o.company_id.state_id.name or ''"/> ,
                    <t t-esc="o.company_id.country_id.name or ''"/><br/>
                    GSTIN: <t t-esc="o.company_id.vat or '-'"/>
                </td>
               

                <!-- PO Info -->
               <td style="width:50%; border:1px solid #000; padding:5px; vertical-align:top;">
    <table style="width:100%; border-collapse:collapse; font-size:13px;">
        <tr>
            <td style="width:45%; font-weight:bold;">Invoice No</td>
            <td style="width:5%;">:</td>
            <td style="width:50%;"><t t-esc="o.invoice_no or '-'"/></td>
        </tr>
        <tr>
            <td style="font-weight:bold;">Invoice Date</td>
            <td>:</td>
            <td>
                <t t-esc="o.invoice_date"/>
            </td>
        </tr>

        <tr>
            <td style="font-weight:bold;">Terms Of Delivery</td>
            <td>:</td>
            <td>
                <t t-esc="o.terms_of_delivery"/>
            </td>
        </tr>

        <tr>
            <td style="font-weight:bold;">GRN No</td>
            <td>:</td>
            <td><t t-esc="o.name or '-'"/></td>
        </tr>

        <tr>
            <td style="font-weight:bold;">GRN Date</td>
            <td>:</td>
            <td>
                <t t-esc="o.date_done"/>
            </td>
        </tr>
    </table>
</td>


            </tr>
        </table>
        <table style="width:100%; border:1px solid black; border-collapse:collapse; font-size:12px;margin-top:15px;">
            <thead>
                <tr style="background:#f0f0f0;">
                <th style="border:1px solid black; padding:5px;">Part Code</th>
                <th style="border:1px solid black; padding:5px;">Description</th>
                <th style="border:1px solid black; padding:5px;">Inv. Qty</th>
                <th style="border:1px solid black; padding:5px;">UOM</th>
                <th style="border:1px solid black; padding:5px;">Rec. Qty</th>
                <th style="border:1px solid black; padding:5px;">Accepted Qty</th>
                <th style="border:1px solid black; padding:5px;">Rej/Short Qty</th>
                <th style="border:1px solid black; padding:5px;">Warehouse</th>
                </tr>
            </thead>
            <tbody>
                <t t-foreach="o.move_ids_without_package" t-as="l">
                <tr>
                <td style="border:1px solid black; padding:5px;" t-esc="l.product_id.default_code"></td>
                <td style="border:1px solid black; padding:5px;" t-esc="l.product_id.name"></td>
                <td style="border:1px solid black; padding:5px; text-align:right;" t-esc="l.product_uom_qty"></td>
                <td style="border:1px solid black; padding:5px;" t-esc="l.product_uom.name"></td>
                <td style="border:1px solid black; padding:5px; text-align:right;" t-esc="l.quantity"></td>
                <td style="border:1px solid black; padding:5px; text-align:right;" t-esc="l.quantity"></td>
                <td style="border:1px solid black; padding:5px; text-align:right;" t-esc="l.quantity"></td>
                <td style="border:1px solid black; padding:5px;" t-esc="o.location_dest_id.name"></td>
                </tr>
                </t>
            </tbody>
    </table>

<!-- <t t-set="sign_name" t-value="o.user_id.name or 'OdooBot'"/>
 -->
<table style="width:100%; margin-top:120px; border-collapse:collapse;">
    <tr>
        <!-- Prepared By -->
        <td style="width:50%; text-align:left; vertical-align:top;">
            <table style="margin-left:0 50px; border-collapse:collapse;">
                <tr>
                    <td style="
                        width:200px;
                        height:30px;
                        border:1px solid #000;
                        vertical-align:middle;
                        text-align:left;
                        font-size:13px;">
                        <t t-esc="o.prepared_by_id.name"/>
                        <!-- Empty box or name -->
                    </td>
                </tr>
                <tr>
                    <td style="padding-top:6px;text-align:center; font-size:12px;">
                        Prepared By
                    </td>
                </tr>
            </table>
        </td>

        <!-- Accepted By -->
        <td style="width:50%;margin-left:-450px; text-align:right; vertical-align:top;">
            <table style="margin-left:250px; border-collapse:collapse;">
                <tr>
                    <td style="
                        width:200px;
                        height:30px;
                        border:1px solid #000;
                        vertical-align:middle;
                        text-align:center;
                        font-size:13px;">
                        <t t-esc="o.approved_by_id.name"/>
                        <!-- Empty box or name -->
                    </td>
                </tr>
                <tr>
                    <td style="padding-top:6px; text-align:center;font-size:12px;">
                        Accepted By
                    </td>
                </tr>
            </table>
        </td>
    </tr>
</table>


    <!-- DOC INFO LINE -->


    <!-- FOOT NOTE -->
    <div style="text-align:center; font-size:11px; margin-top:50px;">
        This is a computer-generated document and does not require a signature.
    </div>




    </div>
    </t> 
</template>


<template id="report_grn_document">
    <t t-call="web.html_container">
        <t t-foreach="docs" t-as="o">
            <t t-call="ek_design_grn.report_grn_custom" t-lang="o.partner_id.lang"/>
        </t>
    </t>
</template>


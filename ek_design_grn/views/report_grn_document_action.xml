<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="paperformat_grn_order" model="report.paperformat">
        <field name="name">Custom GRN Order</field>
        <field name="default">False</field>
        <field name="format">A4</field> <!-- Options: A4, Letter -->
        <field name="orientation">Portrait</field> <!-- Portrait or Landscape -->
        <field name="margin_top">10</field>
        <field name="margin_bottom">10</field>
        <field name="margin_left">10</field>
        <field name="margin_right">10</field>
    </record>

      <record id="action_report_grn" model="ir.actions.report">
        <field name="name">Goods Receipt Note (GRN)</field>
        <field name="model">stock.picking</field>
        <field name="report_type">qweb-pdf</field>
        <field name="report_name">ek_design_grn.report_grn_document</field>
        <field name="report_file">ek_design_grn.report_grn_document</field>
        <field name="binding_model_id" ref="stock.model_stock_picking"/>
        <field name="binding_type">report</field>
        <field name="print_report_name">object.partner_id.name + '_' + object.name</field>
        <field name="paperformat_id" ref="paperformat_grn_order"/>

    </record>
</odoo>


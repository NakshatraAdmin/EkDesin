<?xml version="1.0" encoding="utf-8" ?>
<odoo>
    <record id="order_form_inherit" model="ir.ui.view">
        <field name="name">purchase.order.form.inherit</field>
        <field name="model">purchase.order</field>
        <field name="inherit_id" ref="purchase.purchase_order_form" />
        <field name="arch" type="xml">
            <xpath expr="//header" position="inside">
                <button
                    name="action_create_approval_request"
                    type="object"
                    string="Send For Approval"
                    class="btn-primary"
                    invisible="not is_approval_required or state in ('pending_approval', 'rejected', 'approved')"
                />
                <button
                    name="action_send_for_draft"
                    type="object"
                    string="Send For Draft"
                    class="btn-primary"
                    invisible="state != 'rejected'"
                />
                <button
                    name="action_approve"
                    type="object"
                    string="Approve"
                    class="btn-primary"
                    invisible="not is_show_approve_reject_button"
                />
                <button
                    name="action_reject"
                    type="object"
                    string="Reject"
                    class="btn-danger"
                    invisible="not is_show_approve_reject_button"
                />
            </xpath>

            <xpath
                expr="//header//button[@name='button_confirm'][1]"
                position="attributes"
            >
                <attribute
                    name="invisible"
                >is_approval_required or state in ('draft','pending_approval', 'rejected')</attribute>
            </xpath>
            <xpath
                expr="//header//button[@name='button_confirm'][2]"
                position="attributes"
            >
                <attribute
                    name="invisible"
                >is_approval_required or state in ('draft','pending_approval', 'rejected')</attribute>
            </xpath>
            <xpath
                expr="//header//button[@name='action_rfq_send'][1]"
                position="attributes"
            >
                <attribute
                    name="invisible"
                >is_approval_required or state in ('pending_approval', 'rejected')</attribute>
            </xpath>
            <xpath
                expr="//header//button[@name='print_quotation'][1]"
                position="attributes"
            >
                <attribute
                    name="invisible"
                >is_approval_required or state in ('pending_approval', 'rejected')</attribute>
            </xpath>
            <xpath
                expr="//header//button[@name='button_cancel'][1]"
                position="attributes"
            >
                <attribute
                    name="invisible"
                >is_approval_required or state in ('pending_approval', 'rejected')</attribute>
            </xpath>
            <xpath expr="//field[@name='partner_id']" position="attributes">
                <attribute
                    name="readonly"
                >state in ('cancel', 'done', 'purchase','pending_approval', 'approved','rejected')</attribute>
            </xpath>
            <xpath expr="//field[@name='partner_ref']" position="attributes">
                <attribute
                    name="readonly"
                >state in ('pending_approval', 'approved','rejected')</attribute>
            </xpath>
            <xpath expr="//field[@name='date_order']" position="attributes">
                <attribute
                    name="readonly"
                >state in ('cancel', 'done', 'purchase','pending_approval', 'approved','rejected')</attribute>
            </xpath>
            <xpath expr="//field[@name='date_planned']" position="attributes">
                <attribute
                    name="readonly"
                >state in ('draft', 'sent', 'to approve', 'purchase','pending_approval', 'approved','rejected')</attribute>
            </xpath>
            <xpath expr="//field[@name='order_line']" position="attributes">
                <attribute
                    name="readonly"
                >state in ('cancel', 'done', 'pending_approval', 'approved','rejected')</attribute>
            </xpath>
            <xpath expr="//field[@name='user_id']" position="attributes">
                <attribute
                    name="readonly"
                >state in ('pending_approval', 'approved','rejected')</attribute>
            </xpath>
            <xpath expr="//field[@name='company_id']" position="attributes">
                <attribute
                    name="readonly"
                >state in ('cancel', 'done', 'purchase','pending_approval', 'approved','rejected')</attribute>
            </xpath>
            <xpath expr="//field[@name='user_id']" position="attributes">
                <attribute
                    name="readonly"
                >state in ('pending_approval', 'approved','rejected')</attribute>
            </xpath>
            <xpath expr="//field[@name='origin']" position="attributes">
                <attribute
                    name="readonly"
                >state in ('pending_approval', 'approved','rejected')</attribute>
            </xpath>
            <xpath expr="//field[@name='payment_term_id']" position="attributes">
                <attribute
                    name="readonly"
                >state in ('pending_approval', 'approved','rejected')</attribute>
            </xpath>
            <xpath expr="//field[@name='fiscal_position_id']" position="attributes">
                <attribute
                    name="readonly"
                >state in ('pending_approval', 'approved','rejected')</attribute>
            </xpath>
        </field>
    </record>

    <record id="order_project_form_inherit" model="ir.ui.view">
        <field name="name">purchase.order.project.form.inherit</field>
        <field name="model">purchase.order</field>
        <field
            name="inherit_id"
            ref="project_purchase.view_order_form_inherit_project_purchase"
        />
        <field name="arch" type="xml">
            <xpath expr="//field[@name='project_id']" position="attributes">
                <attribute
                    name="readonly"
                >state in ('pending_approval', 'approved','rejected')</attribute>
            </xpath>
        </field>
    </record>
    <record id="order_picking_form_inherit" model="ir.ui.view">
        <field name="name">purchase.order.picking.form.inherit</field>
        <field name="model">purchase.order</field>
        <field
            name="inherit_id"
            ref="purchase_stock.purchase_order_view_form_inherit"
        />
        <field name="arch" type="xml">
            <xpath expr="//field[@name='picking_type_id']" position="attributes">
                <attribute
                    name="readonly"
                >state in ('cancel', 'done', 'purchase','pending_approval', 'approved','rejected')</attribute>
            </xpath>
            <xpath expr="//field[@name='incoterm_location']" position="attributes">
                <attribute
                    name="readonly"
                >state in ('done','pending_approval', 'approved','rejected')</attribute>
            </xpath>
            <xpath expr="//field[@name='incoterm_id']" position="attributes">
                <attribute
                    name="readonly"
                >state in ('done','pending_approval', 'approved','rejected')</attribute>
            </xpath>
        </field>
    </record>
    <record id="view_purchase_order_search_list" model="ir.ui.view">
        <field name="name">purchase.order.search</field>
        <field name="model">purchase.order</field>
        <field name="arch" type="xml">
            <search string="Search Purchase Order Items">
                <filter
                    name="assigned_approvals"
                    string="My Assigned Approvals"
                    domain="[('assigned_approver_id', '=', uid)]"
                />
            </search>
        </field>
    </record>
    <record id="purchase_order_approval_list" model="ir.ui.view">
        <field name="name">purchase.order.view.list</field>
        <field name="model">purchase.order</field>
        <field name="arch" type="xml">
            <list>
                <field name="name" />
                <field name="partner_id" />
                <field name="user_id" />
                <field name="origin" />
                <field name="amount_total" />
                <field name="assigned_approver_id" />
                <field name="approver_state" />
            </list>
        </field>
    </record>
    <record id="purchase_order_approval_form_action" model="ir.actions.act_window">
        <field name="name">Approval Request for Purchase orders</field>
        <field name="res_model">purchase.order</field>
        <field name="domain">[('state', '=', 'pending_approval')]</field>
        <field name="view_mode">list,form</field>
        <field
            name="context"
        >{'create': False, 'search_default_assigned_approvals': 1}</field>
        <field name="view_id" ref="purchase_order_approval_list" />
        <field name="search_view_id" ref="view_purchase_order_search_list" />
    </record>
    <menuitem
        id="menu_purchase_order_approval_request_form_action"
        action="purchase_order_approval_form_action"
        parent="purchase.menu_procurement_management"
        sequence="50"
    />
</odoo>

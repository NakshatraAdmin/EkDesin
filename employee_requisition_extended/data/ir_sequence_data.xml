<?xml version="1.0" encoding="UTF-8" ?>
<odoo>
    <data noupdate="1">
        <!-- Sequence for Material Requisition -->
        <record id="ir_sequence_material_requisition" model="ir.sequence">
            <field name="name">Material Requisition</field>
            <field name="code">employee.material.requisition</field>
            <field name="prefix">MR</field>
            <field name="padding">5</field>
            <field eval="1" name="number_next"/>
            <field eval="1" name="number_increment"/>
            <field eval="False" name="company_id"/>
        </record>

        <!-- Sequence for Purchase Requisition -->
        <record id="ir_sequence_purchase_requisition_extended" model="ir.sequence">
            <field name="name">Purchase Requisition (Extended)</field>
            <field name="code">employee.purchase.requisition.extended</field>
            <field name="prefix">PR</field>
            <field name="padding">5</field>
            <field eval="1" name="number_next"/>
            <field eval="1" name="number_increment"/>
            <field eval="False" name="company_id"/>
        </record>
    </data>
</odoo>

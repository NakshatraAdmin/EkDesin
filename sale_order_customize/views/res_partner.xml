<odoo>
    <record id="view_partner_form_group_flags" model="ir.ui.view">
        <field name="name">res.partner.form.group.flags</field>
        <field name="model">res.partner</field>
        <field name="inherit_id" ref="base.view_partner_form"/>
        <field name="arch" type="xml">

            <xpath expr="//sheet/group" position="inside">
                <group string="Partner Type">
                    <field name="is_customer_partner"/>
                    <field name="is_vendor_partner"/>
                    <field name="is_internal_partner"/>
                </group>
            </xpath>

        </field>
    </record>
</odoo>

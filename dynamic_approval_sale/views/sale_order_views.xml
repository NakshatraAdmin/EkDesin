<?xml version="1.0" encoding="utf-8" ?>
<odoo>
    <record id="sale_order_form_quote_inherit_approval" model="ir.ui.view">
        <field name="name">sale.order.form.inherit.approval</field>
        <field name="model">sale.order</field>
        <field name="inherit_id" ref="sale_management.sale_order_form_quote" />
        <field name="arch" type="xml">
            <xpath expr="//field[@name='sale_order_template_id']" position="attributes">
                <attribute
                    name="readonly"
                >state in ('cancel', 'sale', 'pending_approval', 'approved','rejected')</attribute>
            </xpath>
        </field>
    </record>
    <record id="order_form_inherit" model="ir.ui.view">
        <field name="name">sale.order.form.inherit</field>
        <field name="model">sale.order</field>
        <field name="inherit_id" ref="sale.view_order_form" />
        <field name="arch" type="xml">
            <xpath expr="//header" position="inside">
                <button
                    name="action_create_approval_request"
                    type="object"
                    string="Send For Approval"
                    class="btn-primary"
                    invisible="not is_approval_required or state in ('pending_approval', 'rejected', 'approved')"
                />
                <button
                    name="action_send_for_draft"
                    type="object"
                    string="Send For Draft"
                    class="btn-primary"
                    invisible="state != 'rejected'"
                />
                <button
                    name="action_approve"
                    type="object"
                    string="Approve"
                    class="btn-primary"
                    invisible="not is_show_approve_reject_button"
                />
                <button
                    name="action_reject"
                    type="object"
                    string="Reject"
                    class="btn-danger"
                    invisible="not is_show_approve_reject_button"
                />
            </xpath>
            <xpath
                expr="//header//button[@name='action_confirm'][1]"
                position="attributes"
            >
                <attribute
                    name="invisible"
                >is_approval_required or state in ('draft', 'pending_approval', 'rejected')</attribute>
            </xpath>
            <xpath
                expr="//header//button[@name='action_quotation_send'][1]"
                position="attributes"
            >
                <attribute
                    name="invisible"
                >is_approval_required or state in ('draft','pending_approval', 'rejected')</attribute>
            </xpath>
            <xpath
                expr="//header//button[@name='action_preview_sale_order'][1]"
                position="attributes"
            >
                <attribute
                    name="invisible"
                >is_approval_required or state in ('draft','pending_approval', 'rejected')</attribute>
            </xpath>
            <xpath
                expr="//header//button[@name='action_cancel']"
                position="attributes"
            >
                <attribute
                    name="invisible"
                >is_approval_required or state in ('draft','pending_approval', 'rejected')</attribute>
            </xpath>
            <xpath expr="//field[@name='partner_id']" position="attributes">
                <attribute
                    name="readonly"
                >state in ('cancel', 'sale', 'pending_approval', 'approved','rejected')</attribute>
            </xpath>
            <xpath expr="//field[@name='validity_date']" position="attributes">
                <attribute
                    name="readonly"
                >state in ('cancel', 'sale', 'pending_approval', 'approved','rejected')</attribute>
            </xpath>
            <xpath expr="//field[@name='date_order']" position="attributes">
                <attribute
                    name="readonly"
                >state in ('cancel', 'sale', 'pending_approval', 'approved','rejected')</attribute>
            </xpath>
            <xpath expr="//field[@name='validity_date']" position="attributes">
                <attribute
                    name="readonly"
                >state in ('cancel', 'sale', 'pending_approval', 'approved','rejected')</attribute>
            </xpath>
            <xpath expr="//field[@name='date_order'][1]" position="attributes">
                <attribute
                    name="readonly"
                >state in ('cancel', 'sale', 'pending_approval', 'approved','rejected')</attribute>
            </xpath>
            <xpath expr="//field[@name='date_order'][2]" position="attributes">
                <attribute
                    name="readonly"
                >state in ('cancel', 'sale', 'pending_approval', 'approved','rejected')</attribute>
            </xpath>
            <xpath expr="//field[@name='payment_term_id']" position="attributes">
                <attribute
                    name="readonly"
                >state in ('cancel', 'sale', 'pending_approval', 'approved','rejected')</attribute>
            </xpath>
            <xpath expr="//field[@name='order_line']" position="attributes">
                <attribute
                    name="readonly"
                >state in ('cancel', 'pending_approval', 'approved','rejected') or locked</attribute>
            </xpath>
            <xpath expr="//field[@name='user_id']" position="attributes">
                <attribute
                    name="readonly"
                >state in ('pending_approval', 'approved','rejected')</attribute>
            </xpath>
            <xpath expr="//field[@name='team_id']" position="attributes">
                <attribute
                    name="readonly"
                >state in ('pending_approval', 'approved','rejected')</attribute>
            </xpath>
            <xpath expr="//field[@name='company_id']" position="attributes">
                <attribute
                    name="readonly"
                >state in ('pending_approval', 'approved','rejected')</attribute>
            </xpath>

            <xpath expr="//field[@name='require_signature']" position="attributes">
                <attribute
                    name="readonly"
                >state in ('cancel', 'sale','pending_approval', 'approved','rejected')</attribute>
            </xpath>
            <xpath expr="//field[@name='require_payment']" position="attributes">
                <attribute
                    name="readonly"
                >state in ('cancel', 'sale','pending_approval', 'approved','rejected')</attribute>
            </xpath>
            <xpath expr="//field[@name='prepayment_percent']" position="attributes">
                <attribute
                    name="readonly"
                >state in ('cancel', 'sale','pending_approval', 'approved','rejected')</attribute>
            </xpath>
            <xpath expr="//field[@name='reference']" position="attributes">
                <attribute
                    name="readonly"
                >state in ('pending_approval', 'approved','rejected')</attribute>
            </xpath>
            <xpath expr="//field[@name='client_order_ref']" position="attributes">
                <attribute
                    name="readonly"
                >state in ('pending_approval', 'approved','rejected')</attribute>
            </xpath>
            <xpath expr="//field[@name='tag_ids']" position="attributes">
                <attribute
                    name="readonly"
                >state in ('pending_approval', 'approved','rejected')</attribute>
            </xpath>
            <xpath expr="//field[@name='fiscal_position_id']" position="attributes">
                <attribute
                    name="readonly"
                >state in ('pending_approval', 'approved','rejected')</attribute>
            </xpath>
            <xpath expr="//field[@name='journal_id']" position="attributes">
                <attribute
                    name="readonly"
                >invoice_count != 0 and state in ('sale') or state in ('pending_approval', 'approved','rejected')</attribute>
            </xpath>
            <xpath expr="//field[@name='invoice_status']" position="attributes">
                <attribute
                    name="readonly"
                >state in ('pending_approval', 'approved','rejected')</attribute>
            </xpath>
            <xpath expr="//field[@name='commitment_date']" position="attributes">
                <attribute
                    name="readonly"
                >state in ('cancel','pending_approval', 'approved','rejected') or locked</attribute>
            </xpath>
            <xpath expr="//field[@name='expected_date']" position="attributes">
                <attribute
                    name="readonly"
                >state in ('cancel','pending_approval', 'approved','rejected') or locked</attribute>
            </xpath>
            <xpath expr="//field[@name='origin']" position="attributes">
                <attribute
                    name="readonly"
                >state in ('pending_approval', 'approved','rejected')</attribute>
            </xpath>
            <xpath expr="//field[@name='campaign_id']" position="attributes">
                <attribute
                    name="readonly"
                >state in ('cancel','pending_approval', 'approved','rejected')</attribute>
            </xpath>
            <xpath expr="//field[@name='medium_id']" position="attributes">
                <attribute
                    name="readonly"
                >state in ('cancel','pending_approval', 'approved','rejected')</attribute>
            </xpath>
            <xpath expr="//field[@name='source_id']" position="attributes">
                <attribute
                    name="readonly"
                >state in ('pending_approval', 'approved','rejected')</attribute>
            </xpath>
        </field>
    </record>
    <record id="order_project_form_inherit" model="ir.ui.view">
        <field name="name">sale.order.project.form.inherit</field>
        <field name="model">sale.order</field>
        <field
            name="inherit_id"
            ref="sale_project.view_order_form_inherit_sale_project"
        />
        <field name="arch" type="xml">
            <xpath expr="//field[@name='project_id']" position="attributes">
                <attribute
                    name="readonly"
                >state in ('pending_approval', 'approved','rejected')</attribute>
            </xpath>
        </field>
    </record>
    <record id="view_sale_order_search_list" model="ir.ui.view">
        <field name="name">sale.order.search</field>
        <field name="model">sale.order</field>
        <field name="arch" type="xml">
            <search string="Search Sale Order Items">
                <filter
                    name="assigned_approvals"
                    string="My Assigned Approvals"
                    domain="[('assigned_approver_id', '=', uid)]"
                />
            </search>
        </field>
    </record>
    <record id="sale_order_approval_list" model="ir.ui.view">
        <field name="name">sale.order.view.list</field>
        <field name="model">sale.order</field>
        <field name="arch" type="xml">
            <list>
                <field name="name" />
                <field name="create_date" />
                <field name="partner_id" />
                <field name="user_id" />
                <field name="amount_total" />
                <field name="assigned_approver_id" />
                <field name="approver_state" />
            </list>
        </field>
    </record>
    <record id="sale_order_approval_form_action" model="ir.actions.act_window">
        <field name="name">Approval Request for Sale orders</field>
        <field name="res_model">sale.order</field>
        <field name="domain">[('state', '=', 'pending_approval')]</field>
        <field name="view_mode">list,form</field>
        <field
            name="context"
        >{'create': False, 'search_default_assigned_approvals': 1}</field>
        <field name="view_id" ref="sale_order_approval_list" />
        <field name="search_view_id" ref="view_sale_order_search_list" />
    </record>
    <menuitem
        id="menu_sale_order_approval_request_form_action"
        action="sale_order_approval_form_action"
        parent="sale.sale_order_menu"
        groups="sales_team.group_sale_salesman"
        sequence="50"
    />
</odoo>

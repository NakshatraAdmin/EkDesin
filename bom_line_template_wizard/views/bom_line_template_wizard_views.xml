<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <odoo>
  <record id="view_select_product_template_wizard_form" model="ir.ui.view">
    <field name="name">select.product.template.wizard.form</field>
    <field name="model">select.product.template.wizard</field>
    <field name="arch" type="xml">
      <form string="Select Product Template">
        <group>
          <field name="product_tmpl_id"/>
        </group>
        <group>
           <field name="attribute_value_ids"
                 widget="many2many_tags"
                 modifiers='{"invisible": [["product_tmpl_id","=", false]]}'
                 placeholder="Choose attribute values to filter variants"
                 domain="[('id','in', attribute_value_ids)]"/>
          <field name="product_ids"
                 widget="many2many_tags"
                 modifiers='{"invisible": [["product_tmpl_id","=", false]]}'
                  domain="[('product_tmpl_id','=', product_tmpl_id)]"
                 placeholder="Variants matching selected attribute values"/>
        </group>
        <group>
          <field name="qty"/>
          <field name="product_uom_id"/>
        </group>
        <footer>
          <button string="Apply" type="object" name="action_apply_to_bom_line" class="btn-primary"/>
          <button string="Cancel" class="btn-secondary" special="cancel"/>
        </footer>
      </form>
    </field>
  </record>
</odoo>


    <record id="action_select_product_template_wizard" model="ir.actions.act_window">
        <field name="name">Select Product Template</field>
        <field name="res_model">select.product.template.wizard</field>
        <field name="view_mode">form</field>
        <field name="target">new</field>
    </record>

    <record id="view_mrp_bom_form_inherit_template_wizard" model="ir.ui.view">
        <field name="name">mrp.bom.form.template.wizard.inherit</field>
        <field name="model">mrp.bom</field>
        <field name="inherit_id" ref="mrp.mrp_bom_form_view"/>
        <field name="arch" type="xml">
                <xpath expr="//field[@name='bom_line_ids']//field[@name='product_id']" position="after">
                <button name="action_open_select_template_wizard" type="object" string="Add Line (Template)" class="oe_highlight"/>
            </xpath>
        </field>
    </record>
    <record id="view_mrp_bom_form_inherit_template_wizard" model="ir.ui.view">
        <field name="name">mrp.bom.form.template.wizard.inherit</field>
        <field name="model">mrp.bom</field>
        <field name="inherit_id" ref="mrp.mrp_bom_form_view"/>
        <field name="arch" type="xml">
                <xpath expr="//field[@name='product_qty']" position="after">
                <button name="action_open_select_template_wizard" type="object" string="Add Line (Template)" class="oe_highlight"/>
            </xpath>
        </field>
    </record>

  
</odoo>

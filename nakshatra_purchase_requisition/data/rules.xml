<?xml version="1.0" encoding="utf-8" ?>
<odoo>
    <record id="rule_pr_line_user_access" model="ir.rule">
        <field name="name">PR Line: User/Approver/Admin Access</field>
        <field
            name="model_id"
            ref="nakshatra_purchase_requisition.model_nakshatra_purchase_requisition_line"
        />
        <field
            name="domain_force"
        >['|','|',('create_uid', '=', user.id),('assigned_approver_id', '=', user.id), ('admin_user_id', '=', user.id)]</field>
        <field
            name="groups"
            eval="[(4, ref('base.group_user')),(4, ref('nakshatra_purchase_requisition.group_pr_admin')),(4, ref('nakshatra_purchase_requisition.group_pr_user'))]"
        />
        <field name="perm_read" eval="True" />
        <field name="perm_write" eval="True" />
        <field name="perm_create" eval="True" />
        <field name="perm_unlink" eval="True" />
    </record>
</odoo>

<?xml version="1.0" encoding="UTF-8" ?>
<odoo>
    <record id="view_purchase_requisition_form" model="ir.ui.view">
        <field name="name">purchase.requisition.form</field>
        <field name="model">nakshatra.purchase.requisition</field>
        <field name="arch" type="xml">
            <form string="Purchase Requisition" create="true" edit="true">
                <header>
                    <button
                        class="btn btn-primary"
                        name="button_send_to_approval"
                        type="object"
                        invisible="hide_send_approval_btn and not is_approval_required"
                        string="Send For Approval"
                        data-hotkey="q"
                    />
                    <button
                        name="action_cancel_pr"
                        type="object"
                        string="Cancel"
                        class="btn btn-danger"
                        invisible="(state in ['approved','cancelled'] or not show_send_cancel_button) and is_approval_required"
                        data-hotkey="w"
                    />
                    <field name="state" readonly="1" widget="statusbar" />
                </header>
                <sheet>
                    <div class="oe_title">
                        <h1>
                            <field name="name" readonly="1" />
                        </h1>
                    </div>
                    <group>
                        <group>
                            <field
                                name="project_id"
                                required="1"
                                readonly="state != 'draft'"
                            />
                            <field name="hide_send_approval_btn" invisible="1" />
                            <field name="is_approval_required" invisible="1" />
                            <field
                                name="reference"
                                readonly="state != 'draft'"
                                invisible="1"
                            />
                            <field
                                name="approval_request_id"
                                readonly="1"
                                invisible="state == 'draft'"
                            />
                            <field
                                name="sale_order_id"
                                invisible="sale_order_id == False"
                            />
                            <field
                                name="mrp_ids"
                                string="Manufacturing Orders"
                                widget="many2many_tags"
                                readonly="sale_order_id != False"
                            />
                        </group>
                        <group>
                            <field name="pr_date" readonly="state != 'draft'" />
                            <field name="create_uid" readonly="1" />
                            <field name="company_id" readonly="1" invisible="1" />
                            <field
                                name="good_line_ids"
                                style="max-height: 200px;overflow-y: auto;"
                            >
                                <list editable="bottom">
                                    <field
                                        name="bom_id"
                                        readonly="is_linked_with_mrp == True"
                                    />
                                    <field
                                        name="required_quantity"
                                        readonly="is_linked_with_mrp == True"
                                    />
                                    <field
                                        name="is_linked_with_mrp"
                                        column_invisible="1"
                                    />
                                </list>
                            </field>
                        </group>
                    </group>
                    <notebook>
                        <page string="Line Items">
                            <field name="line_ids">
                                <list editable="bottom">
                                    <field
                                        name="cancel_selected"
                                        string=""
                                        readonly="item_status in ['approved','cancelled', 'partially_approved']"
                                        invisible="item_status in ['approved','cancelled', 'partially_approved']"
                                    />
                                    <field
                                        name="product_id"
                                        readonly="item_status not in ['draft','rejected','cancelled']"
                                    />
                                    <field
                                        name="image"
                                        widget="image"
                                        string="Product Image"
                                        optional="show"
                                        readonly="item_status not in ['draft','rejected','cancelled']"
                                        class="oe_avatar"
                                    />
                                    <field
                                        name="product_code"
                                        optional="hide"
                                        readonly="item_status not in ['draft','rejected','cancelled']"
                                    />
                                    <field
                                        name="description"
                                        optional="show"
                                        readonly="item_status not in ['draft','rejected','cancelled']"
                                    />
                                    <field
                                        name="required_qty"
                                        readonly="1"
                                        optional="show"
                                        sum="Required Qty"
                                    />
                                    <field
                                        name="available_qty"
                                        readonly="1"
                                        optional="show"
                                        sum="Available Qty"
                                    />
                                    <field
                                        name="free_qty"
                                        readonly="1"
                                        optional="show"
                                        sum="Free Qty"
                                    />
                                    <field
                                        name="requested_qty"
                                        optional="show"
                                        readonly="item_status not in ['draft','rejected','cancelled']"
                                        sum="Requested Qty"
                                    />
                                    <field
                                        name="approved_qty"
                                        readonly="1"
                                        optional="show"
                                        sum="Approved Qty"
                                    />
                                    <field name="uom_id" readonly="1" optional="show" />
                                    <field
                                        name="item_status"
                                        widget="badge"
                                        decoration-info="item_status == 'draft'"
                                        decoration-primary="item_status == 'to_approve'"
                                        decoration-success="item_status == 'approved'"
                                        decoration-warning="item_status == 'rejected'"
                                        readonly="1"
                                        optional="show"
                                    />
                                    <field name="date_planned" optional="hide" />
                                </list>
                            </field>
                        </page>
                        <page string="Notes" readonly="state != 'draft'">
                            <field name="notes" />
                        </page>
                    </notebook>
                </sheet>
                <div class="o_attachment_preview" />
                <chatter />
            </form>
        </field>
    </record>
    <!-- Search View -->
    <record id="view_nakshatra_purchase_requisition_line_search" model="ir.ui.view">
        <field name="name">nakshatra.purchase.requisition.line.search</field>
        <field name="model">nakshatra.purchase.requisition.line</field>
        <field name="arch" type="xml">
            <search string="Search PR Items">
                <!-- Filters -->
                <filter
                    name="draft"
                    string="Draft"
                    domain="[('item_status', '=', 'draft')]"
                />
                <filter
                    name="to_approve"
                    string="Waiting"
                    domain="[('item_status', '=', 'to_approve')]"
                />
                <filter
                    name="approved"
                    string="Approved"
                    domain="[('item_status', '=', 'approved')]"
                />
                <filter
                    name="rejected"
                    string="Rejected"
                    domain="[('item_status', '=', 'rejected')]"
                />
                <!-- Fields to search -->
                <field name="product_id" />
                <field name="description" />
                <field name="product_code" />
                <field name="pr_id" />
                <!-- Group By -->
                <group expand="1" string="Group By">
                    <filter
                        name="group_by_status"
                        string="Item Status"
                        context="{'group_by': 'item_status'}"
                    />
                    <filter
                        name="group_by_pr"
                        string="PR"
                        context="{'group_by': 'pr_id'}"
                    />
                    <filter
                        name="group_by_project"
                        string="Project"
                        context="{'group_by': 'project_id'}"
                    />
                </group>
            </search>
        </field>
    </record>
    <record id="view_purchase_requisition_line_tree" model="ir.ui.view">
        <field name="name">nakshatra.purchase.requisition.line.tree</field>
        <field name="model">nakshatra.purchase.requisition.line</field>
        <field name="arch" type="xml">
            <list
                string="PR Items"
                default_order="date_planned desc"
                create="false"
                delete="0"
                editable="bottom"
            >
                <header>
                    <button
                        class="btn btn-primary"
                        name="action_approve_reject_items"
                        type="object"
                        string="Approve/Reject"
                    />
                    <button
                        class="btn btn-primary"
                        name="action_reject_all_items"
                        type="object"
                        string="Reject All"
                    />
                </header>
                <field name="pr_date" widget="date" readonly="1" />
                <field name="pr_id" readonly="1" />
                <field name="product_id" readonly="1" />
                <field name="description" readonly="1" />
                <field name="product_code" readonly="1" />
                <field name="approved_qty" sum="Approved Qty" />
                <field name="requested_qty" sum="Requested Qty" readonly="1" />
                <field name="received_qty" sum="Received Qty" readonly="1" />
                <field name="pending_qty" sum="Pending Qty" readonly="1" />
                <field name="date_planned" widget="date" readonly="1" />
                <field name="pr_date" widget="date" readonly="1" optional="show" />
                <field name="pr_id" readonly="1" optional="show" />
                <field name="product_id" readonly="1" optional="show" />
                <field
                    name="image"
                    widget="image"
                    options="{'size': [50, 50]}"
                    readonly="1"
                    optional="show"
                    string="Product Image"
                />
                <field name="description" readonly="1" optional="show" />
                <field name="product_code" readonly="1" optional="show" />
                <field
                    name="requested_qty"
                    sum="Requested Qty"
                    readonly="1"
                    optional="show"
                />
                <field
                    name="received_qty"
                    sum="Received Qty"
                    readonly="1"
                    optional="show"
                />
                <field
                    name="pending_qty"
                    sum="Pending Qty"
                    readonly="1"
                    optional="show"
                />
                <field name="date_planned" widget="date" readonly="1" optional="show" />
                <field
                    name="item_status"
                    widget="badge"
                    decoration-info="item_status == 'draft'"
                    decoration-primary="item_status == 'to_approve'"
                    decoration-success="item_status == 'approved'"
                    decoration-warning="item_status == 'rejected'"
                    readonly="1"
                    optional="show"
                />
                <field name="project_id" readonly="1" optional="show" />
                <field name="po_id" optional="hide" readonly="1" />
                <field name="po_datetime" widget="date" optional="hide" readonly="1" />
                <field name="picking_id" optional="hide" readonly="1" />
                <field
                    name="picking_datetime"
                    widget="date"
                    optional="hide"
                    readonly="1"
                />
            </list>
        </field>
    </record>
    <record id="view_purchase_requisition_tree" model="ir.ui.view">
        <field name="name">purchase.requisition.list</field>
        <field name="model">nakshatra.purchase.requisition</field>
        <field name="arch" type="xml">
            <list string="Purchase Requisitions">
                <field name="name" />
                <field name="pr_date" />
                <field name="project_id" />
                <field name="reference" column_invisible="1" />
                <field name="sale_order_id" />
                <field
                    name="mrp_ids"
                    string="Manufacturing Orders"
                    widget="many2many_tags"
                />
                <field
                    name="state"
                    widget="badge"
                    decoration-info="state == 'draft'"
                    decoration-primary="state == 'to_approve'"
                    decoration-success="state == 'approved'"
                    decoration-warning="state == 'partially_approved'"
                />
                <field name="create_uid" />
            </list>
        </field>
    </record>
    <record id="action_purchase_requisition" model="ir.actions.act_window">
        <field name="name">Purchase Requisitions</field>
        <field name="res_model">nakshatra.purchase.requisition</field>
        <field name="view_mode">list,form</field>
        <field name="help" type="html">
            <p
                class="o_view_nocontent_smiling_face"
            >Create your first Purchase Requisition</p>
        </field>
    </record>
    <record id="action_purchase_requisition_line" model="ir.actions.act_window">
        <field name="name">Purchase Requisitions Lines</field>
        <field name="res_model">nakshatra.purchase.requisition.line</field>
        <field name="view_mode">list,form</field>
        <field name="domain">[('item_status',"=","to_approve")]</field>
        <field name="help" type="html">
            <p
                class="o_view_nocontent_smiling_face"
            >Create your first Purchase Requisition</p>
        </field>
        <field
            name="search_view_id"
            ref="view_nakshatra_purchase_requisition_line_search"
        />
        <field name="context">{
            'search_default_group_by_pr': 1, }
<!--            'search_default_group_by_status': 1, }-->
        </field>
    </record>
    <menuitem
        id="menu_purchase_requisition_root"
        name="Purchase Requisitions"
        parent="purchase.menu_procurement_management"
        sequence="-2"
        action="action_purchase_requisition"
    />
    <menuitem
        id="menu_purchase_requisition_line_root"
        name="Purchase Requisition Items"
        parent="purchase.menu_procurement_management"
        sequence="-1"
        action="action_purchase_requisition_line"
        groups="nakshatra_purchase_requisition.group_pr_admin"
    />
</odoo>

<?xml version="1.0" encoding="UTF-8" ?>
<templates xml:space="preserve">
    <t t-inherit="mrp_workorder.MrpDisplayMenuDialog" t-inherit-mode="extension">
        <xpath expr="//Dialog//div[hasclass('button_list')]" position="inside">
            <button
                class="btn btn-outline-secondary d-flex justify-content-between align-items-center p-3 fs-3"
                t-on-click="() => this.callAction('action_create_pr')"
            >
                Create PR <i class="oi oi-chevron-right" />
            </button>
        </xpath>
    </t>
</templates>

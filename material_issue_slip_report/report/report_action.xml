<?xml version="1.0" encoding="utf-8"?>
<odoo>
	<record id="paperformat_material" model="report.paperformat">
        <field name="name">Material Report</field>
        <field name="default">False</field>
        <field name="format">A4</field> <!-- Options: A4, Letter -->
        <field name="orientation">Portrait</field> <!-- Portrait or Landscape -->
        <field name="margin_top">10</field>
        <field name="margin_bottom">10</field>
        <field name="margin_left">10</field>
        <field name="margin_right">10</field>
                <field name="dpi">90</field>

    </record>

    <record id="action_material_issue_slip" model="ir.actions.report">
        <field name="name">Material Issue Slip</field>
        <field name="model">stock.picking</field>
        <field name="report_type">qweb-pdf</field>
        <field name="report_name">material_issue_slip_report.material_issue_slip_pdf</field>
        <field name="report_file">material_issue_slip_report.material_issue_slip_pdf</field>
        <field name="print_report_name">object.partner_id.name + '_' + object.name</field>
        <field name="paperformat_id" ref="paperformat_material"/>
    </record>

</odoo>


<odoo>
    <record id="view_sale_cancel_reason_wizard" model="ir.ui.view">
        <field name="name">sale.cancel.reason.wizard.form</field>
        <field name="model">sale.cancel.reason.wizard</field>
        <field name="arch" type="xml">
            <form string="Cancel Sale Order">
                <group>
                    <field name="reason" placeholder="Enter cancellation reason..."/>
                </group>
                <footer>
                    <button string="Confirm Cancel"
                            type="object"
                            name="action_confirm_cancel"
                            class="btn-danger"/>
                    <button string="Close"
                            special="cancel"
                            class="btn-secondary"/>
                </footer>
            </form>
        </field>
    </record>
</odoo>

<?xml version="1.0" encoding="UTF-8" ?>
<odoo>
    <record id="view_stock_picking_form_inherit_approval" model="ir.ui.view">
        <field name="name">stock.picking.form.inherit.approval</field>
        <field name="model">stock.picking</field>
        <field name="inherit_id" ref="stock.view_picking_form" />
        <field name="arch" type="xml">
            <xpath expr="//button[@name='action_confirm']" position="attributes">
                <attribute name="invisible">state != 'approved'</attribute>
            </xpath>
            <header position="inside">
                <button
                    class="btn btn-primary"
                    name="button_send_for_approval"
                    type="object"
                    invisible="not is_approval_required or state != 'draft'"
                    string="Send For Approval"
                    data-hotkey="q"
                />
                <button
                    class="btn btn-primary"
                    name="button_send_to_draft"
                    type="object"
                    invisible="state != 'rejected'"
                    string="Set to Draft"
                    data-hotkey="q"
                />
                <button
                    name="action_approve"
                    type="object"
                    string="Approve"
                    class="btn-primary"
                    invisible="not is_show_approve_reject_button"
                />
                <button
                    name="action_reject"
                    type="object"
                    string="Reject"
                    class="btn-danger"
                    invisible="not is_show_approve_reject_button"
                />
            </header>
            <xpath expr="//button[@name='button_validate']" position="attributes">
                <attribute
                    name="invisible"
                >state in ('draft', 'confirmed', 'done', 'cancel', 'pending_approval', 'approved', 'rejected')</attribute>
            </xpath>
            <xpath expr="//button[@name='button_validate'][2]" position="attributes">
                <attribute
                    name="invisible"
                >state in ('draft', 'waiting', 'assigned', 'done', 'cancel', 'pending_approval', 'approved', 'rejected')</attribute>
            </xpath>
            <xpath expr="//field[@name='partner_id']" position="attributes">
                <attribute
                    name="readonly"
                >state in ('cancel', 'done', 'pending_approval', 'approved')</attribute>
            </xpath>
            <xpath expr="//field[@name='picking_type_id']" position="attributes">
                <attribute
                    name="readonly"
                >state in ('cancel', 'done', 'pending_approval', 'approved')</attribute>
            </xpath>
            <xpath expr="//field[@name='scheduled_date']" position="attributes">
                <attribute
                    name="readonly"
                >state in ('cancel', 'done', 'pending_approval', 'approved')</attribute>
            </xpath>
            <xpath expr="//field[@name='origin']" position="attributes">
                <attribute
                    name="readonly"
                >state in ('cancel', 'done', 'pending_approval', 'approved')</attribute>
            </xpath>
            <xpath
                expr="//field[@name='move_ids_without_package']"
                position="attributes"
            >
                <attribute
                    name="readonly"
                >state in ('done', 'pending_approval', 'approved') and is_locked</attribute>
            </xpath>
            <xpath expr="//field[@name='move_type']" position="attributes">
                <attribute
                    name="readonly"
                >state in ('cancel', 'done', 'pending_approval', 'approved')</attribute>
            </xpath>
            <xpath expr="//field[@name='user_id']" position="attributes">
                <attribute
                    name="readonly"
                >state in ('cancel', 'done', 'pending_approval', 'approved')</attribute>
            </xpath>
        </field>
    </record>
    <record id="view_stock_picking_search_list" model="ir.ui.view">
        <field name="name">stock.picking.search</field>
        <field name="model">stock.picking</field>
        <field name="arch" type="xml">
            <search string="Search Stocks Items">
                <filter
                    name="assigned_approvals"
                    string="My Assigned Approvals"
                    domain="[('assigned_approver_id', '=', uid)]"
                />
            </search>
        </field>
    </record>
    <record id="stock_picking_approval_list" model="ir.ui.view">
        <field name="name">stock.picking.view.list</field>
        <field name="model">stock.picking</field>
        <field name="arch" type="xml">
            <list>
                <field name="name" />
                <field name="partner_id" />
                <field name="origin" />
                <field name="company_id" />
                <field name="assigned_approver_id" />
                <field name="approver_state" />
            </list>
        </field>
    </record>
    <record id="stock_trasfer_approval_action" model="ir.actions.act_window">
        <field name="name">Approval Request for Transfers</field>
        <field name="res_model">stock.picking</field>
        <field name="domain">[('state', '=', 'pending_approval')]</field>
        <field name="view_mode">list,form</field>
        <field
            name="context"
        >{'create': False,'search_default_assigned_approvals': 1}</field>
        <field name="view_id" ref="stock_picking_approval_list" />
        <field name="search_view_id" ref="view_stock_picking_search_list" />
    </record>
    <menuitem
        id="menu_stock_trasfer_approval_action"
        action="stock_trasfer_approval_action"
        parent="stock.menu_stock_transfers"
        sequence="40"
    />
</odoo>

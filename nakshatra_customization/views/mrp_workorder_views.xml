<?xml version="1.0" encoding="UTF-8" ?>
<odoo>
    <record id="mrp_production_work_order_form_view_inherit_pr_mrp" model="ir.ui.view">
        <field name="name">mrp.production.work.order.form.inherited</field>
        <field name="model">mrp.workorder</field>
        <field name="inherit_id" ref="mrp.mrp_production_workorder_form_view_inherit" />
        <field name="arch" type="xml">
            <xpath expr="//header" position="inside">
                <button
                    name="action_create_purchase_requisition"
                    type="object"
                    string="Create PR"
                    class="btn-primary"
                />
            </xpath>
            <xpath expr="//div[@name='button_box']" position="inside">
                <button
                    name="action_view_purchase_requisitions"
                    class="oe_stat_button"
                    type="object"
                    icon="fa-shopping-cart"
                    invisible="purchase_requisition_count == 0"
                >
                    <field
                        name="purchase_requisition_count"
                        widget="statinfo"
                        string="Purchase Requisitions"
                    />
                </button>
            </xpath>
        </field>
    </record>
</odoo>

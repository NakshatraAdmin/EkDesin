<odoo>
    <record id="purchase_order_form_roundoff" model="ir.ui.view">
        <field name="name">purchase.order.form.roundoff</field>
        <field name="model">purchase.order</field>
        <field name="inherit_id" ref="purchase.purchase_order_form"/>
        <field name="arch" type="xml">

            <!-- Add after total -->
            <xpath expr="//field[@name='tax_totals']" position="after">
               

            <field name="amount_roundoff"  colspan="2"  widget="monetary" readonly="1" options="{'currency_field': 'currency_id'}"  style="font-weight: bold;"
                         />
                      <field name="amount_total_rounded" colspan="2"  
                        widget="monetary" readonly="1" string="Final Total"
                         options="{'currency_field': 'currency_id'}" style="font-weight: bold;" />
                     </xpath>

             <xpath expr="//sheet/notebook" position="inside">
                <page string="Purchase Data">
                    <group>
                        <field name="doc_no"/>
                        <field name="revision_no"/>
                        <field name="revision_date"/>
                        <field name="reference_date"/>
                        <field name="terms_of_delivery"/>
                    </group>
                </page>
            </xpath>

        </field>
    </record>
</odoo>

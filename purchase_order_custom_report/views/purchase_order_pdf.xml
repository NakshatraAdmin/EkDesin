       <!--  <div style="font-size:11px; text-align:center; margin-top:2px;">
            Page <span class="page"></span> / <span class="topage"></span>
        </div> 

    </xpath>-->
</template>


<template id="purchase_order_pdf">
    <t t-call="web.html_container">
        <t t-foreach="docs" t-as="o">
            <t t-call="purchase_order_custom_report.report_purchaseorder_custom" t-lang="o.partner_id.lang"/>
        </t>
    </t>
</template>

 <record id="purchase.action_report_purchase_order" model="ir.actions.report">
        <field name="report_name">purchase_order_custom_report.purchase_order_pdf</field>
        <field name="report_file">purchase_order_custom_report.purchase_order_pdf</field>
        <field name="name">Purchase Order</field>
    </record>

</odoo>


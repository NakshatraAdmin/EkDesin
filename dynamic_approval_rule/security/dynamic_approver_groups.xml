<?xml version="1.0" encoding="UTF-8" ?>
<odoo>
    <!-- Create a new security group category (header) -->
    <record model="ir.module.category" id="group_category_dynamic_approver">
        <field name="name">Dynamic Approver</field>
        <field name="description">Access rights for approval</field>
        <field name="sequence">30</field>
    </record>
    <record id="group_dynamic_approver_role" model="res.groups">
        <field name="name">Dynamic Approver Role</field>
        <field
            name="category_id"
            ref="dynamic_approval_rule.group_category_dynamic_approver"
        />
        <field
            name="comment"
        >This group gives access for multilevel approval features.</field>
    </record>
</odoo>
